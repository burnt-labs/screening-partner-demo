# Screening by Burnt — Partner API demo config.
# Copy this file to .env and fill in your values:  cp .env.example .env
# .env is gitignored — never commit a real key.

# Your partner API key (a real secret). Generate one in the Burnt dashboard:
# Settings → Developers → API keys. Shown once at creation.
BURNT_API_KEY=bvk_your_partner_key_here

# MUST match the environment where the key was minted — a key from a different
# environment just returns 401.
#   local:   http://localhost:5173
#   staging: https://app.staging.screening.burnt.com
#   demo:    https://app.demo.screening.burnt.com
#   live:    https://app.screening.burnt.com
BURNT_BASE_URL=https://app.staging.screening.burnt.com

# Port this demo server listens on.
PORT=4000

# Optional — only needed to verify inbound webhooks. Copy the signing secret
# from the dashboard (Settings → Developers → Webhooks).
BURNT_WEBHOOK_SECRET=
